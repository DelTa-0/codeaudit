{
  "name": "codeaudit-scan",
  "version": "0.2.0",
  "description": "Static scan for AI-generated technical debt — hallucinated (phantom) npm dependencies and dead-code candidates. Runs locally, no account needed.",
  "keywords": [
    "cli",
    "static-analysis",
    "dependencies",
    "npm-audit",
    "dead-code",
    "ai",
    "slopsquatting",
    "supply-chain-security"
  ],
  "author": "CodeAudit",
  "license": "MIT",
  "homepage": "https://github.com/DelTa-0/codeaudit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DelTa-0/codeaudit.git",
    "directory": "cli"
  },
  "bugs": "https://github.com/DelTa-0/codeaudit/issues",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codeaudit-scan": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@codeaudit/engine": "*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0"
  }
}
