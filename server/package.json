    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.77.0",
    "pg": "^8.13.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
